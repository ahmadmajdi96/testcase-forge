# ---- Server ----
NODE_ENV=development
PORT=8080
HOST=0.0.0.0
LOG_LEVEL=info

# Comma separated. When empty, the service runs unauthenticated (local/dev only).
# These keys belong to the "default" tenant.
SERVICE_API_KEYS=
# Tenant-scoped keys: "tenantA:key1,tenantA:key2,tenantB:key3".
# Each key maps to exactly one tenant; jobs and artifacts are isolated per tenant.
TENANT_API_KEYS=
# Where terminal job results (test cases, coverage) are persisted per tenant.
ARTIFACTS_DIR=artifacts

# ---- Upload limits ----
MAX_FILES_PER_JOB=40
MAX_FILE_BYTES=10485760
MAX_TOTAL_BYTES=52428800

# ---- Novita ----
NOVITA_API_KEY=sk_replace_me
NOVITA_BASE_URL=https://api.novita.ai/v3/openai
NOVITA_MODEL=deepseek/deepseek-v3.2
NOVITA_MAX_TOKENS=8000
NOVITA_TEMPERATURE=0.2
NOVITA_TIMEOUT_MS=180000
NOVITA_MAX_RETRIES=4
NOVITA_CIRCUIT_FAILURE_THRESHOLD=8
NOVITA_CIRCUIT_RESET_MS=30000

# ---- Generation ----
GENERATION_CONCURRENCY=4
MAX_ITEMS_PER_UNIT=8
MAX_REPAIR_ROUNDS=2
MAX_GLOBAL_REPAIR_ROUNDS=2
JOB_RETENTION_MS=86400000
MAX_ACTIVE_JOBS=200
