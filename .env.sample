# =============================================================================
# testcase-forge — environment sample
# Copy to `.env` and fill in the values. `.env` is gitignored; never commit it.
# Only NOVITA_API_KEY is strictly required; everything else has a default.
# =============================================================================

# ---- Server ----
NODE_ENV=development                 # development | test | production
PORT=8080                            # port the service listens on INSIDE the container
HOST=0.0.0.0
LOG_LEVEL=info                       # fatal | error | warn | info | debug | trace | silent

# Host port published by docker compose (host:8080 -> container). Compose only.
HOST_PORT=8225

# ---- Authentication ----
# "default" tenant keys (comma separated). Leave empty ONLY in dev; production
# requires at least one key across SERVICE_API_KEYS / TENANT_API_KEYS.
SERVICE_API_KEYS=
# Tenant-scoped keys "tenant:key" (comma separated). Each key maps to one tenant;
# jobs, codegen, runs and artifacts are isolated per tenant.
TENANT_API_KEYS=acme:sk_acme_key,globex:sk_globex_key

# ---- Persistence ----
# Where terminal job / codegen / run artifacts are written, per tenant.
ARTIFACTS_DIR=artifacts

# ---- Upload limits ----
MAX_FILES_PER_JOB=40
MAX_FILE_BYTES=10485760              # 10 MiB per file
MAX_TOTAL_BYTES=52428800            # 50 MiB per request

# ---- Novita AI (required) ----
NOVITA_API_KEY=sk_replace_me         # REQUIRED — your Novita API key
NOVITA_BASE_URL=https://api.novita.ai/v3/openai
# Must support json_schema OR json_object (auto-fallback). Good picks:
#   deepseek/deepseek-v3.2 (default), openai/gpt-oss-120b (faster)
NOVITA_MODEL=deepseek/deepseek-v3.2
NOVITA_MAX_TOKENS=8000
NOVITA_TEMPERATURE=0.2
NOVITA_TIMEOUT_MS=180000
NOVITA_MAX_RETRIES=4
NOVITA_CIRCUIT_FAILURE_THRESHOLD=8
NOVITA_CIRCUIT_RESET_MS=30000

# ---- Test-case generation ----
GENERATION_CONCURRENCY=4             # parallel Novita calls (1-32)
MAX_ITEMS_PER_UNIT=8                 # coverage items per generation unit (1-40)
MAX_REPAIR_ROUNDS=2                  # per-unit coverage repair rounds (0-5)
MAX_GLOBAL_REPAIR_ROUNDS=2           # job-level repair for skipped/uncovered items (0-5)
JOB_RETENTION_MS=86400000            # keep terminal jobs in memory for 24h
MAX_ACTIVE_JOBS=200                  # global cap on concurrently active jobs

# ---- Codegen (test cases -> Playwright specs) ----
CODEGEN_CONCURRENCY=3                # parallel spec-file generations (1-16)
CODEGEN_MAX_CASES_PER_FILE=6         # cases per generated spec file (1-20)
MAX_ACTIVE_CODEGEN_PER_TENANT=3      # per-tenant active codegen cap (1-50)

# ---- Test runner (execute Playwright suites) ----
RUNNER_MODE=docker                   # docker = isolated container per run (prod); subprocess = host (dev)
RUNNER_IMAGE=mcr.microsoft.com/playwright:v1.49.1-jammy
# Directory the service writes run workspaces to. Empty => OS temp dir.
RUNNER_WORKSPACE_DIR=
# Host-visible path of RUNNER_WORKSPACE_DIR — REQUIRED in docker mode when the
# service itself runs in a container (so the daemon can bind-mount the workspace).
RUNNER_HOST_WORKSPACE_DIR=
RUN_TIMEOUT_MS=900000                # hard cap per run (30000-3600000)
MAX_ACTIVE_RUNS_PER_TENANT=2         # per-tenant active run cap (1-20)

# =============================================================================
# Runtime-only values (NOT read by the service; passed per test-run request or
# consumed by the generated Playwright suite). Documented here for convenience.
# =============================================================================
# TEST_USER_EMAIL=you@example.com    # credentials the generated auth.setup uses
# TEST_USER_PASSWORD=                 # supplied per run; held in memory only, never persisted
# BASE_URL=https://your-app.example.com
# AUTH_PATH=/auth                     # login route for auth.setup
# TEST_LOCALE=en                      # UI language forced before hydration
# TEST_LOCALE_KEY=locale              # localStorage key the app reads locale from
